# === macOS ===
# https://github.com/github/gitignore/blob/main/Global/macOS.gitignore

.DS_Store
.localized
__MACOSX/
.AppleDouble
.LSOverride
._*

# === VS Code ===
# https://github.com/github/gitignore/blob/main/Global/VisualStudioCode.gitignore

.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
!.vscode/*.code-snippets
*.vsix


# === Kustomize Helm charts ===
# Downloaded by kustomize build --enable-helm
infrastructure/*/charts/

# === Kustomize secret env files ===
# Generated by run.sh with runtime credentials
bootstrap/dev/cluster-secrets/secrets/*.env
infrastructure/gitea/secrets/*.env

# === Terraform ===
*.tfstate
*.tfstate.backup
.terraform/
.terraform.lock.hcl
terraform/clusters/*-config
